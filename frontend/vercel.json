{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mobifone-website.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://mobifone-website.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}